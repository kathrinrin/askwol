@prefix : <http://w3id.org/askwol/broken/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix neverused: <http://example.org/never/used/> .
@prefix mixedhost: <https://w3id.org/askwol/broken/> .

# -----------------------------------------------------------------------------
# A deliberately broken sample ontology - every askwol check should fire here.
#
# Use this to eyeball the rendered HTML report end-to-end. Drop the file into
# the upload form at http://localhost:8000/ (or POST it to /api/validate) and
# walk through the report sections top to bottom.
#
# What each check should report:
#
#   1. Ontology metadata     - FAIL (5 required missing) + WARN (3 recommended)
#   2. Imports               - WARN (the non-resolvable vocab below is used in
#                              the ontology but not declared in owl:imports).
#                              foaf/skos are treated as well-known core
#                              vocabularies and are intentionally not flagged.
#   3. IRI strategy          - WARN (mixes hash AND slash style for own terms)
#   4. IRI scheme            - WARN (w3id.org appears under http:// and https://)
#   5. Namespaces            - FAIL (the nonexistent.invalid host does not
#                              resolve, and the term cannot be looked up there)
#   6. Definition docs       - FAIL (Orphan has no rdfs:label/rdfs:comment;
#                              Organization is missing the rdfs:comment)
#   7. Language tags         - WARN (mixed @en + untagged label on Person)
#   8. Reasoner              - FAIL (Alice is both Person and NotPerson which
#                              are owl:disjointWith)
#   9. Unused prefixes       - WARN (neverused is declared but not used in any
#                              triple)
# -----------------------------------------------------------------------------

# (1) Ontology declaration with NO metadata at all - missing title, creator,
# license, version, etc. Triggers the metadata SHACL shapes.
<http://w3id.org/askwol/broken/> a owl:Ontology .

# (2) + (3) Hash-style term (good practice on its own, but see slash term below)
:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:label "Person" ;                # (7) mixed: tagged AND untagged
    rdfs:comment "A human being."@en ;
    rdfs:subClassOf foaf:Agent .         # (2) foaf used but not imported

:NotPerson a owl:Class ;
    rdfs:label "Not a person"@en ;
    rdfs:comment "Complement of Person."@en ;
    owl:disjointWith :Person .

# (3) Slash-style term in the SAME ontology - mixes IRI strategies
<http://w3id.org/askwol/broken/Organization> a owl:Class ;
    rdfs:label "Organization"@en .
    # (6) deliberately no rdfs:comment - definition-docs should flag this

# (6) Class with no documentation at all
:Orphan a owl:Class .

# (3) Hash-style term in the SAME ontology stem (`http://w3id.org/askwol/broken`)
# alongside slash-style :Person, :NotPerson etc. - mixes IRI strategies.
<http://w3id.org/askwol/broken#LegacyThing> a owl:Class ;
    rdfs:label "Legacy thing"@en ;
    rdfs:comment "Defined with a hash IRI in a slash ontology."@en .

:knows a owl:ObjectProperty ;
    rdfs:label "knows"@en ;
    rdfs:comment "Acquaintance relation."@en ;
    rdfs:domain :Person ;
    rdfs:range :Person ;
    skos:prefLabel "knows"@en .          # (2) skos used but not imported

# (8) Reasoner: Alice is asserted as both Person and NotPerson, which are
# disjoint - the consistency check should fail.
:alice a :Person, :NotPerson ;
    rdfs:label "Alice"@en ;
    :knows :bob .

:bob a :Person ;
    rdfs:label "Bob"@en .

# (4) IRI scheme: the same host (w3id.org) is referenced under https:// here
# while the ontology IRI above uses http://. The check should flag this host.
:bob rdfs:seeAlso <https://w3id.org/askwol/broken/Person> .

# (5) A subject under a non-resolvable namespace, used as a class reference.
# This exercises the resolver and the term validator FAIL path. The host is
# RFC 2606 reserved so it will never resolve.
<http://nonexistent.invalid/vocab#Widget> a owl:Class ;
    rdfs:label "Widget"@en ;
    rdfs:comment "From a vocabulary that does not resolve."@en .
